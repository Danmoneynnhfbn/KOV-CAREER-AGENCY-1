  <script>
    (function() {
      var menu = document.getElementById('site-mobile-menu');
      var openButton = document.querySelector('[data-mobile-menu-toggle]');
      var closeButton = document.querySelector('[data-mobile-menu-close]');
      var menuLinks = document.querySelectorAll('[data-mobile-menu-link]');
      if (!menu || !openButton || !closeButton) return;
      function toggleMenu(open) {
        var isOpen = menu.classList.contains('is-open');
        var nextState = open === undefined ? !isOpen : open;
        menu.classList.toggle('is-open', nextState);
        menu.setAttribute('aria-hidden', String(!nextState));
        document.body.classList.toggle('mobile-nav-open', nextState);
      }
      openButton.addEventListener('click', function() { toggleMenu(true); });
      closeButton.addEventListener('click', function() { toggleMenu(false); });
      menuLinks.forEach(function(link) { link.addEventListener('click', function() { toggleMenu(false); }); });
    })();
  </script>

  <script>
